LLM_PROVIDER=mlx
# mlx_lm.load() uses local directory only — see resolve_mlx_model_path() in config.py
# Priority: LLM_MODEL_PATH → data/models/mlx → ~/.cache/huggingface/hub/...
LLM_MODEL=mlx-community/Qwen2.5-3B-Instruct-4bit
EMBEDDING_MODEL=intfloat/multilingual-e5-small
DATABASE_PATH=./data
REPO_ROOT=.

# Local dev settings (loaded by app/backend/config.py)

DATABASE_PATH=./data

# --- Embedding model (RAG ingest + retrieval) ---
EMBEDDING_MODEL=intfloat/multilingual-e5-small

# --- Chat model (reply generation) ---
# LLM_PROVIDER: template | openai_compat | gemini
#   template       — emotion templates only (no model call)
#   openai_compat  — OpenAI-compatible API (local MLX server, Ollama, OpenAI, …)
#   gemini         — Google Gemini
LLM_PROVIDER=openai_compat
LLM_MODEL=mlx-community/Qwen2.5-3B-Instruct-4bit

# openai_compat
LLM_API_BASE=http://100.90.225.26:8080/v1
# LLM_API_KEY=                 # optional Bearer token

# gemini (uncomment and set LLM_PROVIDER=gemini)
# GEMINI_API_KEY=
# LLM_MODEL=gemini-2.0-flash
